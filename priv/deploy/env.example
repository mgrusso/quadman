# /etc/quadman/env
# Copy to /etc/quadman/env, chmod 600, chown quadman:quadman

SECRET_KEY_BASE=GENERATE_WITH_mix_phx_gen_secret
DATABASE_PATH=/var/lib/quadman/quadman.db
PHX_HOST=quadman.example.com
PORT=4000

# Optional overrides (defaults shown):
# PODMAN_SOCKET_PATH=/run/user/1000/podman/podman.sock
# QUADLET_DIR=/home/quadman/.config/containers/systemd
# QUADLET_SECRET_DIR=/home/quadman/.config/quadman/secrets
# SYSTEMD_SCOPE=user
# POOL_SIZE=5

# Caddy integration (disabled by default)
# CADDY_ENABLED=true
# CADDY_ADMIN_URL=http://localhost:2019
